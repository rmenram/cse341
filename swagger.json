{
  "swagger": "2.0",
  "info": {
    "title": "Movies API",
    "description": "My cse341 Movies API",
    "version": "1.0.0"
  },
  "host": "localhost:8080",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["Welcome"],
        "description": "Are we logged in or logged out?",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/movies/": {
      "get": {
        "tags": ["Movies"],
        "description": "Get all the movies in the collection.",
        "produces": [
          "application/json"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": ["Movies"],
        "description": "Add a movie doc to the movie collection.",
        "parameters": [
          {
            "name": "obj",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "example": "The Dark Knight"
                },
                "year": {
                  "example": 2008
                },
                "rated": {
                  "example": "PG-13"
                },
                "released": {
                  "example": "2008-07-18"
                },
                "runtimeMins": {
                  "example": 152
                },
                "genre": {
                  "example": ["Action", "Crime", "Drama"]
                },
                "director": {
                  "example": "Christopher Nolan"
                },
                "actors": {
                  "example": ["Christian Bale", "Heath Ledger", "Aaron Eckhart"]
                },
                "plot": {
                  "example": "When the menace known as the Joker wreaks havoc on Gotham, Batman must accept one of the greatest psychological and physical tests of his ability to fight injustice."
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/movies/{id}": {
      "get": {
        "tags": ["Movies"],
        "description": "Get a single doc from the movie collection using the movie id.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": ["Movies"],
        "description": "Use this endpoint to update a movie doc using an existing movie id.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "obj",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "example": "The Dark Knight"
                },
                "year": {
                  "example": 2008
                },
                "rated": {
                  "example": "PG-13"
                },
                "released": {
                  "example": "2008-07-18"
                },
                "runtimeMins": {
                  "example": 152
                },
                "genre": {
                  "example": ["Action", "Crime", "Drama"]
                },
                "director": {
                  "example": "Christopher Nolan"
                },
                "actors": {
                  "example": ["Christian Bale", "Heath Ledger", "Aaron Eckhart", "Ken Watanabe"]
                },
                "plot": {
                  "example": "When the menace known as the Joker wreaks havoc on Gotham, Batman must accept one of the greatest psychological and physical tests of his ability to fight injustice."
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": ["Movies"],
        "description": "Use this endpoint to delete an existing movie doc using its movie id.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/movies-rank/": {
      "get": {
        "tags": ["Ranks"],
        "description": "This endpoint gets all the movies that have been watched/ranked. The ranking works on a 1-5 integer system. Your typical 5 star system.",
        "produces": [
          "application/json"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": ["Ranks"],
        "description": "Add a movie doc to the movie watched/ranked collection.",
        "parameters": [
          {
            "name": "obj",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "example": "The Dark Knight"
                },
                "year": {
                  "example": 2008
                },
                "rated": {
                  "example": "PG-13"
                },
                "stars": {
                  "example": 1
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/movies-rank/{id}": {
      "get": {
        "tags": ["Ranks"],
        "description": "Get a single doc from the movie watched/ranked collection using the movie id.",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "put": {
        "tags": ["Ranks"],
        "description": "Use this endpoint to update a movie doc in the movie watched/ranked collection using an existing movie id.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "obj",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "example": "The Dark Knight"
                },
                "year": {
                  "example": 2008
                },
                "rated": {
                  "example": "PG-13"
                },
                "stars": {
                  "example": 5
                }
              }
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "delete": {
        "tags": ["Ranks"],
        "description": "Use this endpoint to delete an existing movie doc from the movie watched/ranked collection using its movie id.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    }
  },
  "definitions": {}
}